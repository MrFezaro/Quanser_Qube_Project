<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= PROPERTIES ================= -->
  <xacro:property name="box_size" value="0.102"/>
  <xacro:property name="rotor_length" value="0.01"/>
  <xacro:property name="rotor_radius" value="0.025"/>
  <xacro:property name="indicator_length" value="0.025"/>

  <!-- ================= MACRO ================= -->
  <xacro:macro name="joint_model" params="prefix">

    <!-- Base -->
    <link name="${prefix}base_link"/>

    <!-- Stator -->
    <link name="${prefix}stator_link">
      <visual>
        <geometry>
          <box size="${box_size} ${box_size} ${box_size}"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <!-- Rotor -->
    <link name="${prefix}rotor_link">
      <visual>
        <geometry>
          <cylinder length="${rotor_length}" radius="${rotor_radius}"/>
        </geometry>
        <material name="red"/>
      </visual>
    </link>

    <!-- Angle Indicator -->
    <link name="${prefix}angle_link">
      <visual>
        <geometry>
          <box size="${indicator_length} 0.002 0.002"/>
        </geometry>
        <material name="white"/>
      </visual>
    </link>

    <!-- ================= JOINTS ================= -->

    <!-- base -> stator -->
    <joint name="${prefix}stator_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}stator_link"/>
      <origin xyz="0 0 ${box_size/2}" rpy="0 0 0"/>
    </joint>

    <!-- stator -> rotor -->
    <joint name="motor_joint" type="revolute">
      <parent link="${prefix}stator_link"/>
      <child link="${prefix}rotor_link"/>
      <origin xyz="0 0 ${box_size/2 + rotor_length/2}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-3.1416" upper="3.1416" effort="1" velocity="1"/>
    </joint>

    <!-- rotor -> indicator -->
    <joint name="${prefix}indicator" type="fixed">
      <parent link="${prefix}rotor_link"/>
      <child link="${prefix}angle_link"/>
      <origin xyz="0.0125 0 ${rotor_length/2 + 0.0015}" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>
